   1           	; Ficheiro:  ProjetoG19LEIC21D.S
   2           	; Descricao: Ficheiro que implementa o Projeto da disciplina. Este projeto
   3           	;            consiste em fazer um semáforo, em que temos uma rotina de
   4           	;			 passagem de carros, passagem de pedestres e uma rotina de configuração
   5           	;			 onde podemos definir o tempo que demora a passar da rotina de passagem
   6           	;			 de pedestres para a rotina de passagem de carros
   7           	; Autor:     José Saldanha (Nº 51445) e Ricardo Pinto (Nº 51447)
   8           	; Data:      05-06-2024
   9           	
  10           	; Definicao dos valores dos simbolos utilizados no programa
  11           	;
  12          		.equ	CPSR_BIT_I, 0b010000          ; Mascara para o bit I do registo CPSR
  13           	
  14          		.equ	STACK_SIZE, 64                ; Dimensao do stack - 64 B
  15           	
  16           		; Definicoes do porto de entrada
