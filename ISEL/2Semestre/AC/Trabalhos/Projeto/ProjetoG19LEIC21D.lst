 382           	
 383           	; Rotina:    outport_clear_bits
 384           	; Descricao: Atribui o valor logico 0 aos bits do porto de saida identificados
 385           	;            com o valor 1 em R0. O valor dos outros bits nao e alterado.
 386           	;            Interface exemplo: void outport_clear_bits( uint8_t pins_mask );
 387           	; Entradas:  R0 - Mascara com a especificacao do indice dos bits a alterar.
 388           	; Saidas:    -
 389           	; Efeitos:   Altera o valor da variavel global outport_img.
 390           	outport_clear_bits:
 391 01B4 0E 24		push	lr
 392 01B6 B1 0C		ldr	r1, outport_img_addr
 393 01B8 12 08		ldrb	r2, [r1, #0]
 394 01BA 10 B0		mvn	r0, r0
 395 01BC 20 C0		and	r0, r2, r0
 396 01BE 10 28		strb	r0, [r1]
 397 01C0 07 5C		bl	outport_write
 398 01C2 0F 04		pop	pc
 399           	
 400           	; Rotina:    outport_init
 401           	; Descricao: Faz a iniciacao do porto de saida, nele estabelecendo o valor
 402           	;            recebido em R0.
 403           	;            Interface exemplo: void outport_init( uint8_t value );
 404           	; Entradas:  R0 - Valor a atribuir ao porto de saida.
 405           	; Saidas:    -
 406           	; Efeitos:   Altera o valor da variavel global outport_img.
 407           	outport_init:
 408 01C4 0E 24		push	lr
 409 01C6 31 0C		ldr	r1, outport_img_addr
 410 01C8 10 28		strb	r0, [r1]
 411 01CA 02 5C		bl	outport_write
 412 01CC 0F 04		pop	pc
 413           	
 414           	outport_img_addr:
 415 01CE 08 02		.word	outport_img
 416           	
 417           	; Rotina:    outport_write
 418           	; Descricao: Escreve no porto de saida o valor recebido em R0.
 419           	;            Interface exemplo: void outport_write( uint8_t value );
 420           	; Entradas:  R0 - valor a atribuir ao porto de saida.
 421           	; Saidas:    -
 422           	; Efeitos:   -
 423           	outport_write:
 424 01D0 21 0C		ldr	r1, outport_addr
 425 01D2 10 28		strb	r0, [r1, #0]
 426 01D4 0F B7		mov	pc, lr
 427           	
 428           	outport_addr:
 429 01D6 C0 FF		.word	OUTPORT_ADDRESS
 430           	
 431           	; Gestor de periférico para o Pico Timer/Counter (pTC)
 432           	;
 433           	
 434           	; Rotina:    ptc_init
 435           	; Descricao: Faz a iniciacao do periférico pTC, habilitando o seu funcionamento
 436           	;            em modo continuo e com o intervalo de contagem recebido em R0, em
 437           	;            ticks.
 438           	;            Interface exemplo: void ptc_init( uint8_t interval );
 439           	; Entradas:  R0 - Valor do novo intervalo de contagem, em ticks.
 440           	; Saidas:    -
 441           	; Efeitos:   Inicia a contagem no periferico a partir do valor zero, limpando
 442           	;            o pedido de interrupcao eventualmente pendente.
 443           	ptc_init:
 444 01D8 0E 24	    push    lr
 445 01DA 51 0D		ldr	r1, PTC_ADDR
 446 01DC 12 60		mov	r2, #PTC_CMD_STOP
 447 01DE 12 28		strb	r2, [r1, #PTC_TCR]
 448 01E0 10 29		strb	r0, [r1, #PTC_TMR]
 449 01E2 0E 5C	    bl  ptc_clr_irq
 450 01E4 02 60		mov	r2, #PTC_CMD_START
 451 01E6 12 28		strb	r2, [r1, #PTC_TCR]
 452 01E8 0F 04		pop pc
 453           	
 454           	; Rotina:    ptc_start
 455           	; Descricao: Habilita a contagem no periferico pTC.
 456           	;            Interface exemplo: void ptc_start( );
 457           	; Entradas:  -
 458           	; Saidas:    -
 459           	; Efeitos:   -
 460           	ptc_start:
 461 01EA D0 0C		ldr	r0, PTC_ADDR
 462 01EC 01 60		mov	r1, #PTC_CMD_START
 463 01EE 01 28		strb	r1, [r0, #PTC_TCR]
 464 01F0 0F B7		mov	pc, lr
 465           	
 466           	; Rotina:    ptc_stop
 467           	; Descricao: Para a contagem no periferico pTC.
 468           	;            Interface exemplo: void ptc_stop( );
 469           	; Entradas:  -
 470           	; Saidas:    -
 471           	; Efeitos:   O valor do registo TC do periferico e colocado a zero.
 472           	ptc_stop:
 473 01F2 90 0C		ldr	r0, PTC_ADDR
 474 01F4 11 60		mov	r1, #PTC_CMD_STOP
 475 01F6 01 28		strb	r1, [r0, #PTC_TCR]
 476 01F8 0F B7		mov	pc, lr
 477           	
 478           	; Rotina:    ptc_get_value
 479           	; Descricao: Devolve o valor corrente da contagem do periferico pTC.
 480           	;            Interface exemplo: uint8_t ptc_get_value( );
 481           	; Entradas:  -
 482           	; Saidas:    R0 - O valor corrente do registo TC do periferico.
 483           	; Efeitos:   -
 484           	ptc_get_value:
 485 01FA 51 0C		ldr	r1, PTC_ADDR
 486 01FC 10 0A		ldrb	r0, [r1, #PTC_TC]
 487 01FE 0F B7		mov	pc, lr
 488           	
 489           	; Rotina:    ptc_clr_irq
 490           	; Descricao: Sinaliza o periferico pTC que foi atendido um pedido de
 491           	;            interrupção.
 492           	;            Interface exemplo: void ptc_clr_irq( );
 493           	; Entradas:  -
 494           	; Saidas:    -
 495           	; Efeitos:   -
 496           	ptc_clr_irq:
 497 0200 20 0C		ldr	r0, PTC_ADDR
 498 0202 01 2B		strb	r1, [r0, #PTC_TIR]
 499 0204 0F B7		mov	pc, lr
 500           	
 501           	PTC_ADDR:
 502 0206 40 FF		.word	PTC_ADDRESS
 503           	
