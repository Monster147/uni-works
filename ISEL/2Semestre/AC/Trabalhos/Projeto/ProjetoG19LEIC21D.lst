 324           	; Rotina:    sysclk_init
 325           	; Descricao: Inicia uma nova contagem no periferico pTC com o intervalo de
 326           	;            contagem recebido em R0, em ticks, limpando eventuais pedidos de
 327           	;            interrupcao pendentes e iniciando com o valor zero a variavel
 328           	;            global sysclk.
 329           	;            Interface exemplo: void sysclk_init( uint8_t interval );
 330           	; Entradas:  R0 - Valor do novo intervalo de contagem, em ticks.
 331           	; Saidas:    -
 332           	; Efeitos:   Inicia a contagem no periferico a partir do valor zero, limpando
 333           	;            eventuais pedidos de interrupcao pendentes e iniciando com o
 334           	;            valor zero a variavel global sysclk
 335           	sysclk_init:
