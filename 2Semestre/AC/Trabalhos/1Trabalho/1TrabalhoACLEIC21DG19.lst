 158           	3. a) 	;r0 = t, r1 = c, r2, r3 = temp
 159           			color_scale:
 160           				mov  r1, #GREEN_SCALE & 0xFF
 161           				mov  r2, #CRITICAL_TIME & 0xFF
 162           				mov  r3, #WARNING_TIME & 0xFF
 163           				movt r3, #( WARNING_TIME >> 8 ) & 0xFF
 164           			if:
 165           				cmp r0, r2
 166           				blo else_if
 167           				cmp r3, r0
 168           				blo else_if
 169           				mov r1, #AMBAR_SCALE & 0xFF
 170           			else_if:
 171           				cmp r0, r2
 172           				bhs color_scale_ret
 173           				mov r1, #RED_SCALE & 0xFF
 174           			color_scale_ret:
 175           			mov pc, lr
 176           		b) Esta implementaçăo da funçăo color_scale ocupa 26 bytes na memória, uma vez que săo utilizadas 13 instruçőes, em que cada uma utiliza 16 bits, ou seja, 2 bytes.
 177           		
 178           	4.	a) É preferível utilizar o registo R4 para a varíavel i em vez do registo R3, uma vez que durante a execuçăo do código teremos de preservar o valor desta varíavel uma vez que vamos utilizar este valor para ir buscar um elemento de um array e posteriormente vamos ter de o incrementar em 1.
 179           		b) 	;r0/r4 = &array_t[0], r1/r5= &array_c[0], r2 = array_t_size, r6 = i
 180           			test_color_scale:
 181           				push lr
 182           				push r4
 183           				push r5
 184           				push r6
 185           				push r7
 186           				mov r4, r0
 187           				mov r5, r1
 188           				mov r7, r2
 189           				mov r6, #0
 190           			test_color_scale_loop:
 191           				cmp r6, r7
 192           				bhs test_color_scale_end
 193           				mov r3 , r6
 194           				add r3, r3, r3
 195           				ldr r0, [r4, r3]
 196           				bl color_scale
 197           				lsl r0, r0, #1
 198           				ldrb r1, [r5, r0]
 199           				add r1, r1, #1
 200           				strb r5, [r1, r0]
 201           				add r6, r6, #1
 202           				b test_color_scale_loop
 203           			test_color_scale_end:
 204           				mov r5, r1
 205           				pop r7
 206           				pop r6
 207           				pop r5
 208           				pop r4
 209           				pop pc
