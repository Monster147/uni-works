{{#if team}}
  <h3>Team Details:</h3>
  <div class="text-center mb-3">
    <img 
      src={{team.logo}}
      alt="{{team.name}} logo" 
      style="max-width: 200px; height: auto; display: block; margin: 0 auto;"
    />
  </div>
  <table class="table table-striped">
    <thead>
      <tr>
        <th>Name</th>
        <th>Stadium</th>
        <th>Competitions disputed</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>{{team.name}}</td>
        <td>{{team.stadium}}</td>
        <td>
          <ul>
            {{#each team.leagues}}
              <li>{{this.name}} (Season: {{this.season}})</li>
            {{/each}}
          </ul>
        </td>
      </tr>
    </tbody>
  </table>
  <div class="d-flex justify-content-between mt-3">
	  <form action="/site/teams/store" method="POST" class="mt-3">
     <input type="hidden" name="name" value="{{team.name}}">
	    <button type="submit" class="btn btn-success">Add to Teams</button>
	  </form>
	  </div>
{{else}}
  <p class="text-muted">No search has been made.</p>
{{/if}}