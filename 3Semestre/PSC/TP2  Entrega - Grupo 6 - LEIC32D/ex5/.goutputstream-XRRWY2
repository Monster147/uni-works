#include <stdio.h>
#include "../ex4/psc_tp2.h"
#include "ex5.h"

int main() {
	current_cart = malloc(sizeof(Cart) + sizeof(*current_cart->products));
	if (!current_cart) {
		fprintf(stderr, "Erro ao alocar memória para o carrinho.\n");
		return 1;
	}
	current_cart->user_id = 0;
	current_cart->n_products = 0;
	free(current_cart);
    char command[COMMAND_BUFFER_SIZE];

    // Inicializar os dados
    Users *users = users_get();
    all_products = products_get();
    current_cart = malloc(sizeof(Cart) + sizeof(*current_cart->products));
	if (!current_cart) {
		fprintf(stderr, "Erro ao alocar memória para o carrinho.\n");
		return 1;
	}
	current_cart->user_id = 0;
	current_cart->n_products = 0;

    while (true) {
        printf("Comando: ");
        if (!fgets(command, COMMAND_BUFFER_SIZE, stdin)) {
            break;
        }
        command[strcspn(command, "\n")] = '\0'; 

        if (strcmp(command, "Terminar") == 0|| strcmp(command, "terminar") == 0) {
            break;
        } else if (strcmp(command, "Utilizadores") == 0 || strcmp(command, "utilizadores") == 0) {
            list_users(users);
        } else if (strncmp(command, "utilizador", 10) == 0 || strncmp(command, "Utilizador", 10) == 0) {
			int user_id;
			int args = sscanf(command, "utilizador %d", &user_id);
			if (args != 1) {
				if (strncmp(command, "utilizador", 7) == 0) {
				printf("Comando inválido. Use 'utilizador <id>'.\n");
				} 
				else {
					printf("Comando inválido. Use 'Utilizador <id>'.\n");
				}
			} 
			else {
				if(user_id<1){
					printf("User_id inválido, por favor escolha um id maior que 0\n");
				}
				else{
					for (size_t i = 0; i < users->count; i++) {
						if (users->users[i].id == user_id) {
							current_user = &users->users[i];
							printf("Utilizador corrente: %s\n", current_user->name);
							current_cart->user_id = user_id;
							break;
						}
					}
				}
			}
        } 
        else if (strncmp(command, "Produtos", 8) == 0 || strncmp(command, "produtos", 8) == 0) {
			char category[50], order[5];
			int args = sscanf(command, "Produtos %49s %4s", category, order);
				if(args == 2) {
					if (strcmp(order, "<") != 0 && strcmp(order, ">") != 0) {
						printf("Maneira de ordenar desconhecida. Use '<' ou '>'\n");
				} 
					else {
						list_products(category, order);
					}
				} 	
				else {
					printf("Comando inválido. Use 'Produtos <categoria> <ordem>'\n");
				}
        } 
        else if (strcmp(command, "Carrinho") == 0|| strcmp(command, "carrinho") == 0) {
            list_cart();
        } 
        else if (strncmp(command, "Comprar", 7) == 0 || (strncmp(command, "comprar", 7) == 0)) {
            int product_id;
            int quantity;
            int args;
			if (strncmp(command, "comprar", 7) == 0) {
				args = sscanf(command, "comprar %d %u", &product_id, &quantity);
			} else {
				args = sscanf(command, "Comprar %d %u", &product_id, &quantity);
			}
            if (args == 2) {
				if(product_id < 1){
					printf("Id de produto inválido\n");
				}
				else if(quantity < 1){
					printf("Quantidade inválida\n");
				}
				else{
					add_to_cart(product_id, quantity);
					}
            }
            else {
				if (strncmp(command, "comprar", 7) == 0) {
				printf("Comando inválido. Use 'comprar <produto_id> <quantidade>'\n");
				} 
				else {
				printf("Comando inválido. Use 'Comprar <produto_id> <quantidade>'\n");
				}
            }
        } 
        else if (strcmp(command, "Finalizar") == 0 || strcmp(command, "finalizar") == 0) {
			finalize_purchase();
        } 
        else {
            printf("Comando desconhecido.\n");
        }
    }
    
    users_free(users);
    products_free(all_products);
    free(current_cart);

    return 0;
}
