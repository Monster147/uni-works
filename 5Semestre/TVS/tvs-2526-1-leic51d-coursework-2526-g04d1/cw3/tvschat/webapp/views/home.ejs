<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>TVS Chat</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="files/tvs.css" />
    <script src="files/chat.js" defer></script>
  </head>
  <body>
    <div class="image-container">
      <img src="files/isel.png" alt="ISEL" width="164" height="97" />
      <div class="title">
        <p>Técnicas de Virtualização de Sistemas</p>
        <p>System Virtualization Techniques</p>
      </div>
      <img src="files/tvs.png" alt="TVS" width="100" height="100" />
    </div>

    <div class="info">
      <div>
        <span><strong>HOST:</strong> <%= host %></span>
        <span>&nbsp;&nbsp;&nbsp;&nbsp;</span>
        <span><strong>PORT:</strong> <%= port %></span>
      </div>
      <div>
        <span><strong>OLLAMA:</strong> <%= ollamaVersion || '-------' %></span>
      </div>
    </div>

    <% if (!ollamaVersion) { %>
      <div class="warning">(ollama unavailable)</div>
    <% } %>

    <div class="payload">
      <pre><%= message %></pre>
    </div>

    <div class="chat-container">
      <div id="conversation" class="conversation"></div>

      <div class="inputrow">
        <textarea
          id="userInput"
          rows="3"
          placeholder="Write your message here..."
        ></textarea>
        <button id="sendBtn">Send</button>
      </div>
    </div>
  </body>
</html>